        <Label Content="seu ano de nascimento:" HorizontalAlignment="Left" Margin="113,121,0,0" VerticalAlignment="Top" FontSize="14" Grid.ColumnSpan="2" Grid.Column="6"/>
        <TextBox x:Name="EntradaAno" HorizontalAlignment="Left" Margin="48,127,0,0" TextWrapping="Wrap" Text="2003" VerticalAlignment="Top" Width="203" Grid.Column="7" Height="23"/>
        <Button Content="Calcular idade" HorizontalAlignment="Left" Margin="224,235,0,0" VerticalAlignment="Top" Height="45" Width="161" Grid.ColumnSpan="2" Cursor="Cross" FontWeight="Bold" Grid.Column="6" Click="Button_Click"/>

    </Grid>
