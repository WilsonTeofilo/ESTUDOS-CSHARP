        <TextBox x:Name="txtNascimento" HorizontalAlignment="Left" Margin="29,356,0,0" TextWrapping="Wrap" Text="AnoNascimento" VerticalAlignment="Top" Width="171" Height="48" VerticalContentAlignment="Center" FontSize="16" FontWeight="SemiBold" TextAlignment="Center" Visibility="Hidden" Grid.ColumnSpan="2" Grid.Column="5"/>
